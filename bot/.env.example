# Discord Application (discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_PUBLIC_KEY=your_public_key_here
DISCORD_APPLICATION_ID=your_application_id_here

# Redis (thread state persistence)
REDIS_URL=redis://localhost:6379

# AI Provider — Groq (primaire, gratuit, ultra-rapide)
GROQ_API_KEY=your_groq_api_key_here

# AI Provider — Anthropic (optionnel, fallback ou tâches complexes)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HELMo Oracle MCP Server (local en dev, prod = URL publique)
MCP_SERVER_URL=http://localhost:8000/mcp
