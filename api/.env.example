# ══════════════════════════════════════════════════
# HELMo Oracle — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env dans Git
# ══════════════════════════════════════════════════

# ── Environnement ──────────────────────────────────
# "local" = sessions JSON locales
# "production" = sessions Supabase
ENV=local

# ── Base de données Supabase ───────────────────────
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# ── LLM Providers ─────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Provider par défaut ────────────────────────────
LLM_DEFAULT_PROVIDER=groq
LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

# ── Guardian ───────────────────────────────────────
GUARDIAN_PROVIDER=groq
GUARDIAN_MODEL=llama-3.1-8b-instant

# ── Unstructured.io ────────────────────────────────
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_SERVER_URL=https://api.unstructuredapp.io/general/v0/general

# ── Recherche hybride ──────────────────────────────
K_SEMANTIC=10
K_BM25=10
K_FINAL=5
RRF_K=60
FTS_LANG=french

# ── Mémoire ────────────────────────────────────────
MAX_RECENT_TOKENS=1200
MIN_RECENT_MESSAGES=4

# ── Cache sémantique ───────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_DAYS=30
CACHE_MAX_ENTRIES=500

# ── Prompt système ─────────────────────────────────
# Laisser vide si vous utilisez config/prompt.txt
SYSTEM_PROMPT=
