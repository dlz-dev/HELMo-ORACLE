# ══════════════════════════════════════════════════
# HELMo Oracle — api/.env
# Copier en .env et remplir les valeurs
# Ne jamais committer ce fichier dans Git
# ══════════════════════════════════════════════════

# ── Environnement ──────────────────────────────────
# "local" = sessions JSON locales
# "production" = sessions Supabase
ENV=local

# ── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=https://oracle.dlzteam.com,http://localhost:3000

# ── Sécurité API ───────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Doit être identique à API_SECRET_KEY dans web/.env.local
API_SECRET_KEY=f92743c2a78f55e9307b09849f3c354a3b6bedda68d76b5e185e4e307001934d

# ── Base de données vectorielle (documents) ────────
# Mode local (Docker) :
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oracle
# Mode cloud (Digital Ocean / Supabase) :
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Supabase (optionnel — auth, sessions, logs) ────
# Laisser vide pour un déploiement 100% local
SUPABASE_URL=
SUPABASE_ANON_KEY=
LOG_DATABASE_URL=

# ── LLM Providers ─────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Provider par défaut ────────────────────────────
LLM_DEFAULT_PROVIDER=groq
LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

# ── Guardian ───────────────────────────────────────
GUARDIAN_PROVIDER=groq
GUARDIAN_MODEL=llama-3.1-8b-instant

# ── Unstructured.io ────────────────────────────────
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_SERVER_URL=https://api.unstructuredapp.io/general/v0/general

# ── Recherche hybride ──────────────────────────────
K_SEMANTIC=10
K_BM25=10
K_FINAL=5
RRF_K=60
FTS_LANG=french

# ── Redis (bot Discord) ────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=

# ── Mémoire ────────────────────────────────────────
MAX_RECENT_TOKENS=1200
MIN_RECENT_MESSAGES=4

# ── Cache sémantique ───────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_DAYS=30
CACHE_MAX_ENTRIES=500

# ── Prompt système ─────────────────────────────────
# Laisser vide si vous utilisez config/prompt.txt
SYSTEM_PROMPT=