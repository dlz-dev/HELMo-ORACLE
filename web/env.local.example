# ── oracle/api ────────────────────────────────────────────────────
# URL du backend FastAPI (localhost en dev, Railway/Render en prod)
ORACLE_API_URL=http://localhost:8000

# Clé partagée avec oracle/api — identique à API_SECRET_KEY dans api/.env
API_SECRET_KEY=

# ── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Admin ─────────────────────────────────────────────────────────
# Mot de passe de la page /admin
# ⚠️ En prod : ne pas utiliser NEXT_PUBLIC_, gérer côté serveur
NEXT_PUBLIC_ADMIN_PASSWORD=oracle
